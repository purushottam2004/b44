# Copy to `.env` and fill in values. These are read by Vite at build time
# and exposed to the client — only use the public anon key here.

# Supabase project URL (Project Settings → API → Project URL)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase anon public key (Project Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY
